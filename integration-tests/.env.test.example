# Integration Test Environment Configuration
# Copy this to .env.test and customize as needed

# Service URLs
SIM_ENGINE_URL=http://localhost:8101
BACKEND_URL=http://localhost:8102
MANAGEMENT_BACKEND_URL=http://localhost:8180

# Service Ports (separate from dev to avoid conflicts)
SIM_ENGINE_PORT=8101
BACKEND_PORT=8102
MANAGEMENT_PORT=8180

# Database Configuration
DB_HOST=localhost
DB_PORT=5532
DB_NAME=greenhouse_test
DB_USER=test_user
DB_PASSWORD=test_password
DB_URL=jdbc:postgresql://localhost:5532/greenhouse_test

# AWS Configuration (mocked for tests)
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_SESSION_TOKEN=test

# Bedrock Configuration (mocked)
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# MCP Knowledge Base (can be real or mocked)
MCP_KB_ENDPOINT=https://kb-start-hack-gateway-buyjtibfpg.gateway.bedrock-agentcore.us-east-2.amazonaws.com/mcp
USE_MOCK_KB=true

# Authentication tokens for test
AGENT_TOKEN=test-agent-token-12345
SYSTEM_TOKEN=test-system-token-67890

# Test Settings
TEST_TIMEOUT=60
TEST_RETRY_COUNT=3
TEST_RETRY_DELAY=2
LOG_LEVEL=INFO

# Test Data
TEST_SEED=42
TEST_RUN_ID=test-run-001

# Feature Flags for Testing
ENABLE_SLOW_TESTS=false
ENABLE_DB_TESTS=true
ENABLE_BRIDGE_TESTS=true
